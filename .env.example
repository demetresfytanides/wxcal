# wxCal — Weather Calibration Agent

# Local runs with Claude (default):
ANTHROPIC_API_KEY=your-anthropic-key-here

# Local runs with an OpenAI model (e.g. GPT-4o):
# Must also pass --llm <model> when running orchestrator.py, e.g. --llm gpt-4o
#OPENAI_API_KEY=your-openai-key-here

# Motus Cloud: credentials are injected automatically — no .env needed there.
