# wxCal — Weather Calibration Agent
#
# Local (Anthropic direct):
#   Set ANTHROPIC_API_KEY. Leave MOTUS_CLOUD unset.
ANTHROPIC_API_KEY=your-anthropic-key-here

# Motus Cloud:
#   Credentials are injected automatically — no .env needed there.
#   Set MOTUS_CLOUD=1 only if you need to force the cloud client path locally.
#MOTUS_CLOUD=1
