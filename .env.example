# wxCal — Weather Calibration Agent
#
# Local (Anthropic direct):
#   Set ANTHROPIC_API_KEY. Leave MOTUS_CLOUD unset.
ANTHROPIC_API_KEY=your-anthropic-key-here

# Motus Cloud / OpenRouter:
#   Set MOTUS_CLOUD=1 and OPENAI_API_KEY (OpenRouter key).
#   On Motus Cloud these are injected automatically — no .env needed there.
#MOTUS_CLOUD=1
#OPENAI_API_KEY=your-openrouter-key-here
